JBT_SERVICE_NAME=data
JBT_SERVICE_PORT=8105
JBT_LOG_LEVEL=INFO
DATA_STORAGE_ROOT=/runtime/data
DATA_CACHE_ROOT=/runtime/cache
DATA_BACKUP_DIR=/runtime/backup
JBT_DATA_LOG_DIR=/runtime/logs

# 数据源凭证
DATA_TUSHARE_TOKEN=
DATA_AKSHARE_ENABLED=true
AKSHARE_KEY=
TQSDK_PHONE=
TQSDK_PASSWORD=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 飞书通知（三群分流）
FEISHU_ALERT_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/<alert-hook-id>
FEISHU_TRADING_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/<trade-hook-id>
FEISHU_NEWS_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/<info-hook-id>

# 邮件通知
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDR=
SMTP_TO_ADDRS=user1@example.com,user2@example.com
SMTP_USE_SSL=true

# 运维 API 令牌（飞书 P0 按钮回调用）
DATA_OPS_SECRET=
DATA_OPS_URL=http://localhost:8105
