# ==================================================
# JBT Backtest 服务环境变量配置
# ==================================================
# 复制此文件为 .env，填入真实值
#   cp .env.example .env
#
# 请勿将 .env 提交到 Git（已在 .gitignore 中）
# 字段整合来源：J_BotQuant/.env.example（D-BT-02，2026-04-03）

# ─── 服务基础 ─────────────────────────────────────
JBT_SERVICE_NAME=backtest
JBT_SERVICE_PORT=8103
JBT_LOG_LEVEL=INFO                           # DEBUG | INFO | WARNING | ERROR

# ─── 运行模式 ─────────────────────────────────────
JBT_ENV=development                          # development | production
JBT_BACKTEST_MODE=online                     # online（TqSdk 在线回测，唯一允许模式）

# ─── 跨服务 API ───────────────────────────────────
JBT_DATA_API_URL=http://jbt-data:8105
JBT_DECISION_API_URL=http://decision:8104

# ─── TqSdk 配置 ──────────────────────────────────
TQSDK_EDITION=community                      # community | professional
TQSDK_ACCOUNT_TYPE=sim                       # sim（回测阶段只允许 sim）
TQSDK_AUTH_USERNAME=<your-tqsdk-username>    # TqAuth 用户名（必须设置，不允许留空）
TQSDK_AUTH_PASSWORD=<your-tqsdk-password>    # TqAuth 密码（必须设置，不允许留空）
# 以下三项为实盘期配置，回测阶段留空
# TQSDK_BROKER_ID=
# TQSDK_ACCOUNT_ID=
# TQSDK_PASSWORD=

# ─── 策略 YAML 目录 ───────────────────────────────
TQSDK_STRATEGY_YAML_DIR=/runtime/strategies  # Jay.S 上传策略 YAML 的挂载目录

# ─── 回测存储路径 ─────────────────────────────────
BACKTEST_STORAGE_PATH=/runtime/backtests
BACKTEST_REPORT_PATH=/runtime/reports
BACKTEST_RESULT_DIR=/runtime/results         # 单次回测结果输出目录（JSON/Parquet）
BACKTEST_MAX_CONCURRENT=2                    # 最大并发回测任务数（建议 ≤ 4）

# ─── API 认证 ──────────────────────────────────
JBT_JWT_SECRET=                              # 必须设置，运行 openssl rand -hex 32 生成
JBT_JWT_EXPIRE_HOURS=24
JBT_API_RATE_LIMIT=60

# ─── CORS 白名单 ──────────────────────────────────
JBT_CORS_ALLOWED=http://localhost:3001       # 回测看板地址（多个域名用逗号分隔）

# ─── Tushare ─────────────────────────────────────
TUSHARE_TOKEN=<your-tushare-token>           # 从 tushare.pro 获取，勿将真实值提交 Git
