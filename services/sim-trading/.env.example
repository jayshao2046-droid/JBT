# 本文件只含占位符，真实凭证通过运行时 Secret 注入，禁止提交任何真实值

# --- 服务基础配置 ---
SERVICE_PORT=PLACEHOLDER                  # 服务监听端口，默认 8101
LOG_LEVEL=PLACEHOLDER                     # 日志级别，如 INFO / DEBUG / WARNING
ENVIRONMENT=PLACEHOLDER                   # 运行环境标识，如 development / production
APP_ENV=PLACEHOLDER                       # 应用环境别名，与 ENVIRONMENT 保持一致

# --- SimNow 接入凭证 (运行时 Secret，不入 Git) ---
SIMNOW_BROKER_ID=PLACEHOLDER              # SimNow 经纪商 ID
SIMNOW_USER_ID=PLACEHOLDER                # SimNow 账号（投资者 ID）
SIMNOW_PASSWORD=PLACEHOLDER               # SimNow 账号密码，禁止提交真实值
SIMNOW_TRADE_FRONT=PLACEHOLDER            # SimNow 交易前置地址，如 tcp://xxx:yyyy
SIMNOW_MD_FRONT=PLACEHOLDER               # SimNow 行情前置地址，如 tcp://xxx:yyyy

# --- 风控基础默认值 (仅占位，实际由启动参数覆盖) ---
RISK_MAX_SINGLE_LOSS_PCT=PLACEHOLDER      # 单次最大亏损比例，默认 0.5%（如 0.005）
RISK_DAILY_LOSS_PCT_STRATEGY=PLACEHOLDER  # 单策略单日最大亏损比例，默认 1%（如 0.01）
RISK_DAILY_LOSS_PCT_ACCOUNT=PLACEHOLDER   # 账户单日最大亏损比例，默认 2%（如 0.02）
RISK_NAV_DRAWDOWN_REDUCE_ONLY=PLACEHOLDER # 净值回撤触发只减仓阈值，如 0.05（即 5%）
RISK_NAV_DRAWDOWN_HALT=PLACEHOLDER        # 净值回撤触发全停阈值，如 0.10（即 10%）

# --- 告警通知 (运行时 Secret，不入 Git) ---
NOTIFY_FEISHU_ENABLED=PLACEHOLDER         # 是否启用飞书通知通道，填 true 或 false（可独立禁用）
NOTIFY_EMAIL_ENABLED=PLACEHOLDER          # 是否启用邮件通知通道，填 true 或 false（可独立禁用）
# 飞书三群路由（报警群/交易群/资讯群），缺失时统一回退到 FEISHU_WEBHOOK_URL
FEISHU_ALERT_WEBHOOK_URL=PLACEHOLDER      # 报警群 Webhook：P0/P1/P2 风控事件（CTP断线/保证金/风控触发）
FEISHU_TRADE_WEBHOOK_URL=PLACEHOLDER      # 交易群 Webhook：成交回报/订单状态/信号通知
FEISHU_INFO_WEBHOOK_URL=PLACEHOLDER       # 资讯群 Webhook：心跳/系统通知/收盘汇总
FEISHU_WEBHOOK_URL=PLACEHOLDER            # 通用回退 Webhook URL（三群均未配置时使用，禁止提交真实值）
ALERT_EMAIL_SMTP_HOST=PLACEHOLDER         # 邮件告警 SMTP 服务器地址
ALERT_EMAIL_SMTP_PORT=PLACEHOLDER         # SMTP 端口，如 465（SSL）或 587（STARTTLS）
ALERT_EMAIL_SMTP_USER=PLACEHOLDER         # SMTP 鉴权用户名，禁止提交真实值
ALERT_EMAIL_SMTP_PASSWORD=PLACEHOLDER     # SMTP 鉴权密码，禁止提交真实值
ALERT_EMAIL_FROM=PLACEHOLDER              # 发件人邮箱地址
ALERT_EMAIL_TO=PLACEHOLDER                # 收件人邮箱地址，多个用逗号分隔

# --- 阶段预设 (sim/live 最小占位) ---
STAGE=PLACEHOLDER                         # 当前运行阶段，填 sim 或 live

# --- 断网缓存行为 ---
CACHE_SNAPSHOT_PATH=PLACEHOLDER           # 本地快照缓存路径，如 /data/cache/snapshot.json
CACHE_STALE_SECONDS=PLACEHOLDER           # 缓存过期秒数，超过则拒绝使用旧快照（如 60）
