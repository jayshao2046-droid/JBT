# ============================================================
# JBT Dashboard Service — 环境变量模板
# ============================================================
# 使用说明：复制为 .env 并填入实际值，.env 不进入 Git

# ----- 基础服务配置 -----
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=3003
DASHBOARD_LOG_LEVEL=info
DASHBOARD_ENV=development
# development | staging | production

# ----- 上游服务 API 地址 -----
SIM_TRADING_API_URL=http://sim-trading:8101
LIVE_TRADING_API_URL=http://live-trading:8102
BACKTEST_API_URL=http://backtest:8103
DECISION_API_URL=http://decision:8104
DATA_API_URL=http://jbt-data:8105

# ----- 只读聚合开关 -----
DASHBOARD_READONLY=true
# dashboard 始终只读，不发送交易指令

# ----- 决策看板聚合配置 -----
DECISION_PROJECTION_ENABLED=true
DECISION_SNAPSHOT_CACHE_TTL=60
# 研究快照缓存 TTL（秒）
STRATEGY_REPO_ENABLED=true
SIGNAL_REVIEW_ENABLED=true
RESEARCH_CENTER_ENABLED=true

# ----- 刷新间隔配置 -----
OVERVIEW_REFRESH_INTERVAL=30
SIGNAL_REFRESH_INTERVAL=10
PORTFOLIO_REFRESH_INTERVAL=60
# 各页面轮询间隔（秒）

# ----- 通知聚合配置 -----
NOTIFICATION_FEED_ENABLED=true
NOTIFICATION_MAX_ITEMS=100

# ----- 运行模式 -----
NEXT_PUBLIC_API_BASE_URL=http://localhost:3003
NEXT_PUBLIC_ENV=development
