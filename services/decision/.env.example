# ============================================================
# JBT Decision Service — 环境变量模板
# ============================================================
# 使用说明：复制为 .env 并填入实际值，.env 不进入 Git

# ----- 基础服务配置 -----
DECISION_HOST=0.0.0.0
DECISION_PORT=8104
DECISION_WORKERS=2
DECISION_LOG_LEVEL=info
DECISION_ENV=development
# development | staging | production

# ----- 研究窗口配置 -----
RESEARCH_WINDOW_START=09:00
RESEARCH_WINDOW_END=15:30
RESEARCH_TIMEZONE=Asia/Shanghai
OVERNIGHT_RESEARCH_ENABLED=true
# 夜间参数搜索开关（Optuna）

# ----- 本地模型配置 -----
LOCAL_MODEL_MAIN=Qwen3-14B
LOCAL_MODEL_COMPAT=DeepSeek-R1-14B
LOCAL_MODEL_L1=Qwen2.5
LOCAL_MODEL_BASE_URL=http://localhost:11434
# Ollama 服务地址

# ----- 在线模型配置 -----
ONLINE_MODEL_DEFAULT=Qwen3.6-Plus
ONLINE_MODEL_UPGRADE=Qwen3-Max
ONLINE_MODEL_BACKUP=DeepSeek-V3.2
ONLINE_MODEL_DISPUTE=DeepSeek-R1
ONLINE_MODEL_API_KEY=your-api-key-here
ONLINE_MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ----- XGBoost 研究配置 -----
XGBOOST_ENABLED=true
XGBOOST_MODEL_DIR=./runtime/models/xgboost
XGBOOST_N_ESTIMATORS=200
XGBOOST_MAX_DEPTH=6
XGBOOST_LEARNING_RATE=0.05

# ----- LightGBM 适配器（保留占位，默认关闭）-----
LIGHTGBM_ENABLED=false
LIGHTGBM_MODEL_DIR=./runtime/models/lightgbm

# ----- CatBoost 适配器（保留占位，默认关闭）-----
CATBOOST_ENABLED=false
CATBOOST_MODEL_DIR=./runtime/models/catboost

# ----- ONNX Runtime 配置 -----
ONNX_RUNTIME_ENABLED=true
ONNX_MODEL_EXPORT_DIR=./runtime/models/onnx
ONNX_INFERENCE_THREADS=2

# ----- Optuna 参数搜索 -----
OPTUNA_ENABLED=true
OPTUNA_STORAGE=sqlite:///./runtime/optuna/study.db
OPTUNA_N_TRIALS=100
OPTUNA_N_JOBS=2
OPTUNA_STUDY_NAME=decision-xgboost-v1

# ----- SHAP 解释审计 -----
SHAP_ENABLED=true
SHAP_AUDIT_DIR=./runtime/shap
SHAP_MAX_DISPLAY=20

# ----- 执行门禁配置 -----
EXECUTION_GATE_ENABLED=true
EXECUTION_GATE_TARGET=sim-trading
# 首阶段目标服务，固定为 sim-trading
LIVE_TRADING_GATE_VISIBLE=true
LIVE_TRADING_GATE_LOCKED=true
# live-trading 入口：可见但锁定

# ----- 模型路由门禁 -----
MODEL_ROUTER_REQUIRE_BACKTEST_CERT=true
MODEL_ROUTER_REQUIRE_RESEARCH_SNAPSHOT=true
MODEL_ROUTER_MIN_SHARPE=0.5
MODEL_ROUTER_MAX_DRAWDOWN=0.20

# ----- 回测服务集成 -----
BACKTEST_SERVICE_URL=http://localhost:8103
BACKTEST_SERVICE_TIMEOUT=60

# ----- 数据服务集成 -----
DATA_SERVICE_URL=http://localhost:8105
DATA_SERVICE_TIMEOUT=30

# ----- 研究员服务集成（Alienware，与 DATA_SERVICE_URL 独立）-----
RESEARCHER_SERVICE_URL=http://192.168.31.223:8199
# 研究员报告来源，指向 Alienware researcher 服务，不可复用 DATA_SERVICE_URL

# ----- 通知配置 -----
# 三群 Webhook（推荐配置，未配置时回退到 FEISHU_WEBHOOK_URL）
FEISHU_ALERT_WEBHOOK_URL=                    # 报警群（P0/P1/P2 → 此群）
FEISHU_TRADE_WEBHOOK_URL=                    # 交易群（SIGNAL → 此群）
FEISHU_INFO_WEBHOOK_URL=                     # 资讯群（RESEARCH/NOTIFY → 此群）
# 通用兜底（若三群未配置则用此）
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-token
NOTIFY_FEISHU_ENABLED=false
EMAIL_SMTP_HOST=smtp.example.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=your-email@example.com
EMAIL_SMTP_PASSWORD=your-smtp-password
EMAIL_ENABLED=false
EMAIL_FROM=JBT Decision <decision@example.com>
EMAIL_TO=admin@example.com

# ----- 日报配置 -----
DAILY_REPORT_ENABLED=true
DAILY_REPORT_HOUR=18
DAILY_REPORT_MINUTE=0
DAILY_REPORT_TIMEZONE=Asia/Shanghai

# ----- 研究员报告评级配置 -----
RESEARCHER_SCORE_DEDUP_SECONDS=900
# 研究员报告去重窗口（秒），同 report_type+report_id 在窗口内只处理一次

# ----- 研报存储配置 -----
RESEARCH_STORE_MAX_AGE_DAYS=7
# 研报评级结果保留天数，超过此时间的记录将被自动清理

# ----- 三级渐进式熔断优化器（TASK-U0-20260417-004）-----
ENABLE_THREE_TIER_OPTIMIZATION=false
DEEPSEEK_V3_MODEL=deepseek-chat
DEEPSEEK_R1_MODEL=deepseek-reasoner
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
MAX_V3_ITERATIONS=10
R1_TRIGGER_ZERO_COUNT=3
R1_TRIGGER_SMALL_IMPROVEMENT_COUNT=5
MINIMUM_IMPROVEMENT_RATE=0.05

# ----- API 成本监控 -----
DAILY_API_BUDGET=10.0
# 每日 API 预算（美元）

# ----- 上下文压缩 -----
CONTEXT_COMPRESSION_ENABLED=true
CONTEXT_SUMMARIZER_MODEL=qwen2.5:7b
# 每3轮压缩一次历史上下文

# ----- 数据库（可选）-----
DECISION_DB_URL=sqlite:///./runtime/decision.db
# 生产环境替换为 PostgreSQL URL

# ----- 运行时目录（不进 Git）-----
# RUNTIME_DIR=./runtime
# LOGS_DIR=./logs
